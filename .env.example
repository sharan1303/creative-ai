OPENAI_API_KEY=  # Primary provider
HUGGINGFACE_TOKEN=  # Free fallback

# Google Cloud (optional provider)
GOOGLE_PROJECT_ID=
GOOGLE_LOCATION=
GOOGLE_SERVICE_ACCOUNT_JSON=  # Path to service account JSON

# Storage configuration
STORAGE_MODE=  # Options: "local" | "azure" | "s3"
AZURE_STORAGE_CONNECTION_STRING=
AWS_S3_BUCKET=

# Processing configuration
MAX_CONCURRENT_GENERATIONS=  # Limit concurrent GenAI calls
RETRY_MAX_ATTEMPTS=  # Retry failed API calls
RETRY_BACKOFF_FACTOR=  # Exponential backoff multiplier (float|)

# Logging
LOG_LEVEL=  # Options: DEBUG, INFO, WARNING, ERROR

# Provider selection and fallback chain
GENAI_PROVIDER=  # Primary: openai | google | huggingface | mock
GENAI_FALLBACKS=  # Comma-separated fallback order

# Image generation settings - DALL-E 3
DEFAULT_IMAGE_QUALITY=  # Options: standard | hd