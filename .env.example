# --------------------------------------
# GenAI Provider Credentials
# --------------------------------------
OPENAI_API_KEY=

# Do NOT reuse provider keys for API auth. Use a separate token.
API_AUTH_TOKEN=dev-token-123

# Google AI (Gemini Image API)
GOOGLE_AI_API_KEY=
GOOGLE_AI_IMAGE_MODEL=gemini-2.5-flash-image
GOOGLE_AI_ENDPOINT=https://generativelanguage.googleapis.com

# --------------------------------------
# Storage
# --------------------------------------
# Options: local | azure | s3
STORAGE_MODE=local
AZURE_STORAGE_CONNECTION_STRING=
AWS_S3_BUCKET=

# --------------------------------------
# Processing
# --------------------------------------
MAX_CONCURRENT_GENERATIONS=3
RETRY_MAX_ATTEMPTS=3
RETRY_BACKOFF_FACTOR=2.0

# --------------------------------------
# Celery / Redis
# --------------------------------------
REDIS_URL=redis://redis:6379/0
# Optional; falls back to REDIS_URL when unset
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# --------------------------------------
# Logging
# --------------------------------------
# Options: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# --------------------------------------
# Provider selection and fallbacks
# --------------------------------------
# Current primary provider: openai | google
GENAI_PROVIDER=google
# Comma-separated order to try when primary fails
GENAI_FALLBACKS=openai

# Default models per provider
OPENAI_DEFAULT_MODEL=gpt-image-1
GOOGLE_DEFAULT_MODEL=gemini-2.5-flash-image

# Image generation defaults
# OpenAI DALL E 3: standard | hd
# OpenAI gpt-image-1: low | medium | high | auto
DEFAULT_IMAGE_QUALITY=low
DEFAULT_IMAGE_WIDTH=1024
DEFAULT_IMAGE_HEIGHT=1024

# --------------------------------------
# Agent monitoring (LLM for alerts)
# --------------------------------------
# Provider: openai | google
AGENT_LLM_PROVIDER=google
# Optional override; leave empty to use provider-specific default
AGENT_LLM_MODEL=
AGENT_LLM_MODEL_OPENAI=gpt-5-nano
AGENT_LLM_MODEL_GOOGLE=gemini-2.5-flash
AGENT_CHECK_INTERVAL=60
AGENT_SLA_THRESHOLD_MINUTES=10

# --------------------------------------
# Email / SMTP (for alerts)
# --------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@company.com
STAKEHOLDER_EMAIL=creative-lead@company.com

# Slack webhook (optional)
SLACK_WEBHOOK_URL=

# --------------------------------------
# MCP Server
# --------------------------------------
MCP_SERVER_URL=http://localhost:8001
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8001
# Comma-separated origins; use * for any
MCP_CORS_ALLOW_ORIGINS=*