# Primary provider
OPENAI_API_KEY=  
HUGGINGFACE_TOKEN=

# Google Cloud (optional provider)
GOOGLE_PROJECT_ID=
GOOGLE_LOCATION=
GOOGLE_SERVICE_ACCOUNT_JSON=

# Storage configuration
# Options: "local" | "azure" | "s3"
STORAGE_MODE=
AZURE_STORAGE_CONNECTION_STRING=
AWS_S3_BUCKET=

# Processing configuration
MAX_CONCURRENT_GENERATIONS=
# Retry failed API calls
RETRY_MAX_ATTEMPTS=
# Exponential backoff multiplier (float)
RETRY_BACKOFF_FACTOR=  

# Logging
LOG_LEVEL=  # Options: DEBUG, INFO, WARNING, ERROR

# Provider selection and fallback chain
# Primary: openai | google | huggingface | mock
GENAI_PROVIDER=
# Comma-separated fallback order
GENAI_FALLBACKS=  

# Image generation settings
# - DALL-E 3 Options: standard | hd
# - gpt-image-1 Options: low | medium | high | auto
DEFAULT_IMAGE_QUALITY=